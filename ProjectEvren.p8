-- player code

function p_init()
	sprites = {
		up=1, -- up
		dn=2,	-- down
		lt=3, -- left
		rt=4,	-- right
		up_lt=5, -- up left
		up_rt=6, -- up right
		dn_lt=7, -- down left
		dn_rt=8  -- down right
	}
	
	angle = {
		up = 0,
		dn = 180,
		lt = 270,
		rt = 90,
		up_lt = 315,
		up_rt = 45,
		dn_lt = 135,
		dn_rt = 225
	}
	
	cords = {
		x=63,
		y=63,
		speedx=0,
		speedy=0,
	}
	
	sprite = sprites.up
end


function p_update()

	if btn(➡️) then
		cords.speedx =
		cords.x+=cords.speedx
	end
	
	if else btn(⬅️) then	
	 cords.speedx =
		cords.x-=cords.speedx
	end
	
	if else btn(⬇️) then
		cords.speedy = 
		cords.y+=cords.speedy
	end
	
	if else btn(⬆️) then
 	cords.speedy = 
	 cords.y-=cords.speedy
	end
	
	
	if else then 
		
	end
	-- ...

end


function p_draw()
	spr(sprite, cords.x, cords.y)

end

