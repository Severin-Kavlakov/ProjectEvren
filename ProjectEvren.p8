pico-8 cartridge // http://www.pico-8.com
version 42
__lua__
-- main
function _init()
	x=63
	y=63
end

function _update()

	if (btn(➡️))	x+=5
	if (btn(⬅️))	x-=5
	if (btn(⬇️))	y+=5
	if (btn(⬆️))	y-=5
			
end	

function _draw()
	cls()
	spr(1, x, y)
end
