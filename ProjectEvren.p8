-- player code

function p_init()
	sprites = {
		up=1, -- up
		down=2,	-- down
		left=3, -- left
		right=4,	-- right
		up_left=5, -- up left
		up_right=6, -- up right
		down_left=7, -- down left
		down_right=8  -- down right
	}
	
	angle = {
		up    = 0,
		up_right   = 45,
		right = 90,
		down_left  = 135,
		down  = 180,
		up_left    = 315,
		left  = 270,	
		down_right = 225
	}
	
	cords = {
		x=63,
		y=63,
		speedx=0,
		speedy=0,
	}
	
	sprite = sprites.up
end


function p_update()

	if btn(➡️) then
	sprite=sprites.left
		cords.speedx =
		cords.x+=cords.speedx
	end
	
	if else btn(⬅️) then	
	 cords.speedx =
		cords.x-=cords.speedx
	end
	
	if else btn(⬇️) then
		cords.speedy = 
		cords.y+=cords.speedy
	end
	
	if else btn(⬆️) then
 	cords.speedy = 
	 cords.y-=cords.speedy
	end
	
	
	if else then 
		
	end
	-- ...

end


function p_draw()
	spr(sprite, cords.x, cords.y)

end

