-- gravity
-->8
-- render

function pd_rotate(
																			x,y,
																			rot,
																			mx,my,
																			w,
																			flip1, scale
																		)
			
 scale = scale or 1
 w *= scale * 4


 local cs = cos(rot) * .125 
 																	/ scale
 local ss = sin(rot) * .125 
 																	/ scale
 
 local sx = mx + cs * -w
 local sy = my + ss * -w
 
 local hx = flip1 and -w or w

 local halfw = -w
 
 for py=y-w, y+w do
  tline(
				x-hx,        py, 
				x+hx,        py, 
				sx-ss*halfw, sy+cs*halfw, 
				cs,          ss
		)
  halfw+=1
 end
end
-->8
-- trail

function t_init()
	trail = {}
	
	add(trail, {
				x=p.x,
				y=p.y,
				l=2,
				c=10
	})
	
end


function t_update()

	if btn(⬆️) then
		add(trail, {
				x=p.x+4,
				y=p.y+4,
				l=30,
				c=10
			})
	end


	--leave a trace
	--by inverting ship speed
	for part in all(trail) do
		if btn(⬆️) then
			part.x -= p.dx
			part.y += p.dy 
		end
	end
	
	
	for part in all(trail) do
		part.l-=1
		part.c-=1
		
		if part.l < 0	then
				del(trail, part)
		end
	end
	
end

function t_draw()
	for part in all(trail) do
		pset(part.x, part.y, part.c)
	end
	
end
