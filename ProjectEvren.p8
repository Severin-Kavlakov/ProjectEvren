pico-8 cartridge // http://www.pico-8.com
version 42
__lua__
-- main

function _init()
	cls()
	
	plr_init()
	trail_init()
	ui_init()
end


function _update()
	plr_update()
	trail_update()
	ui_update()
end	


function _draw()
	cls()

	plr_draw()
	ui_draw()
	trail_draw()
end
-->8
-- player

function plr_init()	
	p = {
		angle_deg= 0,
		angle = 0/360,
		
		angle_speed =	7.5/360,
		
		speed=0,
		
		x=63,
		y=63,
		dx=0,
		dy=0,
		
		thrust = 0.3,
		friction = 0.85
	}
end
	
	
function plr_update()
	
	if btn(⬆️) then
		p.dx += cos(p.angle) * p.thrust     
		p.dy += sin(p.angle) * p.thrust
	end
	
	if btn(⬅️) then
		p.angle -= p.angle_speed
	end  
	 
	if btn(➡️) then
		p.angle += p.angle_speed
	end
	 
	if (p.angle>1) p.angle=0
	if (p.angle<0) p.angle=1
	
	
	p.dx *= p.friction
	p.dy *= p.friction
	
	p.x += p.dx
	p.y -= p.dy
	
	p.speed = sqrt(p.dx*p.dx+p.dy*p.dy)
	p.angle_degrees = 360 * p.angle
end
	
	
function plr_draw()
		spr(1, p.x, p.y)
		
end

