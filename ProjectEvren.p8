-- player code

function p_init()
	sprites = {
		up    = 1,
		up_right   = 2,
		right = 3, 
		down_right = 4,
		down  = 5,
		down_left  = 6,
		left  = 7,
		up_left    = 8,
	}
	
	angles = {
		up    = 0,
		up_right   = 45,
		right = 90,
		down_left  = 135,
		down  = 180,
		up_left    = 315,
		left  = 270,	
		down_right = 225
	}
	
	x=63
	y=63
	dx=0
	dy=0
	
	sprite = sprites.up
	angle = angles.up--may need for later
	
	thrust = 0.8
end


function p_update()	
			
	
	if btn(⬅️) then
		sprite = sprites.left
	 dx = dx - thrust
	 x = x + dx
	    
	elseif btn(➡️) then
		sprite = sprites.right
		dx = dx + thrust
		x = x + dx
	    
	elseif btn(⬆️) then
		sprite = sprites.up
	 dy = dy - thrust
	 y = y + dy
	    
	elseif btn(⬇️) then
		sprite = sprites.down
	 dy = dy + thrust
	 y = y + dy
	
	elseif (btn(⬆️) and btn(➡️)) then 
		
	elseif (btn(➡️) and btn(⬇️)) then 
	
	elseif (btn(⬇️) and btn(⬅️)) then 
	
	elseif (btn(⬅️) and btn(⬆️)) then 
		
	
	
	end
	
	dx = dx * 0.1
	dy = dy * 0.1
	
end


function p_draw()
	print(dx, 2)
	print(dy, 1)
	
	spr(sprite, x, y)
end

