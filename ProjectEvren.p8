-- player code

function p_init()
	
	angles = {	 
		0,   0.125, 0.25, 0.2625,
		0.5, 0.625, 0.75, 1,
	}
	
	sin_table = {
		sin(0),  sin(0.125), 
		sin(0.25), sin(0.2625),
		sin(0.5), sin(0.625), 
		sin(0.75), sin(1),
	}
	
	cos_table = {
		cos(0),  cos(0.125), 
		cos(0.25), cos(0.2625),
		cos(0.5), cos(0.625), 
		cos(0.75), cos(1),
	}
	
	
	
	angle = 1
	
	x=63
	y=63
	dx=0
	dy=0
	
	thrust = 0.8
	
	sprite = 1
end


function p_update()
	
	if btn(⬆️) then
		dx += cos(angles[angle]) 
		dy += -1 * sin(angles[angle])
		
		x += dx
		y += dy
	end
	
	if btn(⬇️) then
		
	end
	
	if btn(⬅️) then
		sprite -= 1
	 angle  -= 1
	end
	    
	if btn(➡️) then
		sprite += 1
		angle  += 1
	end
	    
	
	if (sprite>8) sprite=1 
	if (sprite<1) sprite=8
	
	if (angle>8) angle=1 
	if (angle<1) angle=8
	
	dx *= 0.75
	dy *= 0.75
end


function p_draw()
	spr(sprite, x, y)
	
	print(sprite, 1)
	print(angles[angle], 1)
	
	print("  ")
	
	print("sin", 1)
	print(sin(angles[angle]), 3)
	print("cos", 1)
	print(cos(angles[angle]), 4)
	
	print("  ")
	
	for i=1,8 do
		print(cos_table[i], 4)
	end
	
end

